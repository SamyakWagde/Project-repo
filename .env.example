# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# JWT Authentication Config:
# Secret key used for signing Access JWTs (generate a strong random secret)
JWT_SECRET="burnout_guardian_super_secret_access_key_918237"
# Secret key used for signing Refresh JWTs
JWT_REFRESH_SECRET="burnout_guardian_super_secret_refresh_key_481023"
